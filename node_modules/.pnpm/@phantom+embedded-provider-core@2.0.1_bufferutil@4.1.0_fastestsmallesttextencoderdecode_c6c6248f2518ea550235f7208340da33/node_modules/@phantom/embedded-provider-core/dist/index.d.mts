    redirectUrl?: string;
    authUrl?: string;
    sessionId: string;
    clearPreviousSession?: boolean;
    allowRefresh?: boolean;
    algorithm?: Algorithm;
}
interface AuthProvider {
    authenticate(options: PhantomConnectOptions): Promise<void | AuthResult>;
